# Reference template. Real production secrets live in Azure Key Vault and
# are injected into Container Apps as `secretref:` env vars — never commit
# them to git. For local dev: copy this file to `.env` and edit.

# --- Database ---
# Local dev with docker-postgres:
#   docker run -d --name bsc-pg -p 5432:5432 \
#     -e POSTGRES_USER=bsc -e POSTGRES_PASSWORD=bsc -e POSTGRES_DB=bsc postgres:16
DATABASE_URL="postgresql://bsc:bsc@localhost:5432/bsc?schema=public"

# --- Auth.js / NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# --- Redis (BullMQ + SSE Pub/Sub) ---
# Empty string => in-process EventEmitter fallback (single replica only).
# Production must set this to enable cross-replica fan-out for live chat.
REDIS_URL=""

# --- Mapbox ---
NEXT_PUBLIC_MAPBOX_TOKEN=""

# --- Email (SMTP first, Resend fallback) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
# Gmail App Password / SMTP password — leave empty in committed files.
SMTP_PASS=""
MAIL_FROM="noreply@example.com"

RESEND_API_KEY=""
EMAIL_FROM="BSC Logistics <noreply@example.com>"

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# --- Azure Blob Storage (file uploads, POD photos) ---
# Use the full connection string from the storage account access keys blade.
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER="uploads"
# Optional CDN / custom-domain origin for publicly readable assets.
AZURE_STORAGE_PUBLIC_URL=""

# --- Observability (Azure Monitor / Application Insights) ---
APPLICATIONINSIGHTS_CONNECTION_STRING=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="en"

# --- Inbound public quote-request mailbox ---
QUOTE_INBOX=""
